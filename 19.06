#include <iostream>
using namespace std;

struct Node {
    int dado;
    Node* prox;
};

void inserirInicio(Node*& head, int valor) {
    Node* novo = new Node{valor, head};
    head = novo;
}

int main() {
    Node* head = nullptr;

    inserirInicio(head, 10);
    inserirInicio(head, 20);

    cout << head->dado << endl;

    return 0;
}
