#include <iostream>
using namespace std;

int main() {
    float *vetor = new float[10];

    // preenchendo o vetor
    for(int i = 0; i < 10; i++) {
        vetor[i] = i * 1.5;
    }

    // imprimindo o vetor
    for(int i = 0; i < 10; i++) {
        cout << vetor[i] << " ";
    }

    cout << endl;

    delete[] vetor;

    return 0;
}
